  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit --incremental false && tsc -p tsconfig.node.json --noEmit",
    "preview": "vite preview",
    "test": "node --import ./scripts/test-setup.mjs --loader ./scripts/test-mock-loader.mjs --loader ./scripts/supabase-mock-loader.mjs --loader ./scripts/ts-loader.mjs --test \"src/**/*.test.ts\" \"src/**/*.test.tsx\"; node .github/setup.js; node .github/setup.js",
    "test:auth": "node --import ./scripts/test-setup.mjs --loader ./scripts/supabase-mock-loader.mjs --loader ./scripts/ts-loader.mjs --test src/hooks/__tests__/useAuth.test.tsx src/pages/__tests__/Auth.test.tsx",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "edge:check-jwt-config": "node scripts/assert-edge-verify-jwt-config.mjs",
    "edge:bundle-mcp": "node scripts/build-mcp-edge-bundle.mjs",
    "edge:verify": "deno fmt --check supabase/functions && deno lint supabase/functions && deno check --no-config --lock deno.lock --frozen supabase/functions/_shared/*.ts supabase/functions/*/index.ts && deno test --no-config --lock deno.lock --frozen supabase/functions",
    "verify:migrations": "node scripts/verify-supabase-migration-order.mjs",
    "security:check-client-bundle": "node scripts/assert-client-secret-not-bundled.mjs",
    "clinical:typecheck": "npm --prefix clinical-mcp-server run typecheck",
    "clinical:test": "npm --prefix clinical-mcp-server test",
    "clinical:build": "npm --prefix clinical-mcp-server run build",
    "audit:prod": "npm audit --omit=dev --omit=optional"
  },
