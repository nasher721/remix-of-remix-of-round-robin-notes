# =============================================================================
# Round Robin Notes — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# ---------------------------------------------------------------------------
# Supabase (required)
# ---------------------------------------------------------------------------
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# ---------------------------------------------------------------------------
# CI / GitHub Actions (repository Secrets — not local .env)
# ---------------------------------------------------------------------------
# Deploy Supabase workflow: set SUPABASE_ANON_KEY to the SAME value as
# VITE_SUPABASE_PUBLISHABLE_KEY for post-deploy healthcheck. Optional:
# VERCEL_DEPLOY_HOOK_URL to redeploy production after edge functions deploy.
# See docs/deployment.md

# ---------------------------------------------------------------------------
# Error monitoring (optional)
# ---------------------------------------------------------------------------
# Sentry browser SDK — set in Vercel Project Settings → Environment Variables (Production + Preview).
# VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
#
# Release string: auto at build = package.json version (+ VERCEL_GIT_COMMIT_SHA on Vercel).
# Override for Sentry release tracking / source maps:
# VITE_APP_VERSION=1.2.3+prod

# ---------------------------------------------------------------------------
# LLM Provider API Keys (set at least one)
# ---------------------------------------------------------------------------
# These keys are used by Supabase Edge Functions (server-side).
# For client-side direct LLM access, prefix with VITE_
#
# OpenAI (GPT-4o, GPT-4o-mini, Whisper)
OPENAI_API_KEY=

# Anthropic (Claude Opus 4, Sonnet 4, Haiku)
ANTHROPIC_API_KEY=

# Google Gemini (Gemini 2.5 Pro, Flash)
GEMINI_API_KEY=

# xAI Grok (Grok 2, Grok 2 Mini)
GROK_API_KEY=

# Zhipu GLM (GLM-4, GLM-4 Flash)
GLM_API_KEY=

# HuggingFace (Llama, Mixtral, etc.)
HUGGINGFACE_API_KEY=
# Optional: custom endpoint for local TGI or Inference Endpoints
# HUGGINGFACE_BASE_URL=

# ---------------------------------------------------------------------------
# LLM Routing Configuration
# ---------------------------------------------------------------------------
# Used by the multi-provider LLM system (src/services/llm/)
# Provides automatic fallback, retry, output validation, and clinical guardrails
# Default provider/model used when no task-specific routing matches
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# Fallback provider/model used when the default fails
FALLBACK_LLM_PROVIDER=gemini
FALLBACK_LLM_MODEL=gemini-2.5-pro

# ---------------------------------------------------------------------------
# Marketing / landing page (optional)
# ---------------------------------------------------------------------------
# Public contact email for mailto links on / (logged-out landing) and /privacy
# VITE_CONTACT_EMAIL=team@yourhospital.org

